              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;&#13;&#10;WHEN &quot;Sales&quot; THEN SUM([Calculation_0281207229145089])&#13;&#10;&#13;&#10;WHEN &quot;Profit&quot; THEN SUM([Calculation_0281207254663178])&#13;&#10;&#13;&#10;WHEN &quot;Orders&quot; THEN COUNTD([Calculation_0649818587742210])&#13;&#10;&#13;&#10;END' />
